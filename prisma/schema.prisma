// JDT Inc. CRM — Prisma schema
// Run `npx prisma generate` after editing.
// Stages/priorities/sources are stored as strings (not Prisma enums) so
// they can be tweaked in `lib/crm.ts` without requiring a DB migration.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  notes      Note[]
  activities Activity[]
}

model Lead {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  company   String?
  phone     String?
  message   String?
  source    String   @default("Website Contact Form")
  status    String   @default("New")
  priority  String   @default("Medium")

  // Qualification (collected on the public contact form or set manually).
  serviceInterest String?
  estimatedBudget String?

  // Sales follow-up signals.
  temperature     String   @default("Cold") // Cold | Warm | Hot
  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes      Note[]
  activities Activity[]

  @@index([status])
  @@index([priority])
  @@index([source])
  @@index([createdAt])
  @@index([temperature])
  @@index([nextFollowUpAt])
}

model Note {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  authorId String?
  author   Admin?  @relation(fields: [authorId], references: [id])

  @@index([leadId])
}

model Activity {
  id        String   @id @default(cuid())
  // e.g. "lead_created", "status_changed", "priority_changed",
  // "note_added", "lead_updated"
  type      String
  // Freeform JSON context, e.g. { from: "New", to: "Contacted" }
  meta      Json?
  createdAt DateTime @default(now())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  authorId String?
  author   Admin?  @relation(fields: [authorId], references: [id])

  @@index([leadId])
  @@index([createdAt])
}
