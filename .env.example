# -------------------------------------------------------------
# JDT Inc. — Environment variables
# Copy this file to `.env` for local dev (and add the same vars
# to Vercel → Project Settings → Environment Variables).
# -------------------------------------------------------------

# Postgres connection string (Neon recommended).
# Neon provides a pooled URL — use that here for serverless runtimes.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Secret used to sign admin session JWTs.
# Generate one with: openssl rand -base64 48
AUTH_SECRET="replace-me-with-a-long-random-string"

# Initial admin account (used by `npm run db:seed`).
# Change the password after first login.
# ADMIN_EMAIL is also the recipient of new-lead email notifications.
ADMIN_EMAIL="admin@jdtinc.com"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_NAME="JDT Admin"

# -------------------------------------------------------------
# Lead email notifications (Resend)
# -------------------------------------------------------------
# Get a key at https://resend.com/api-keys
# Leave RESEND_API_KEY blank locally to disable notifications (the
# app still works; it just skips sending emails).
RESEND_API_KEY=""

# Verified sender — must be on a domain you've verified in Resend.
# Format: "JDT Inc <leads@notifications.jdtinc.com>"
# For quick local testing, "onboarding@resend.dev" is allowed by Resend
# and will deliver only to the account's own email.
RESEND_FROM="JDT Inc <leads@notifications.jdtinc.com>"

# Base URL used to build links inside the email (e.g. to the lead page).
# Optional locally — defaults to the site URL from `lib/site.ts`.
# Set to "http://localhost:3000" while testing emails from dev.
APP_URL=""

# -------------------------------------------------------------
# Follow-up automation (Vercel Cron)
# -------------------------------------------------------------
# Shared secret required to trigger the cron endpoints:
#   GET /api/cron/follow-ups
#   GET /api/cron/daily-digest
# Vercel Cron automatically sends "Authorization: Bearer $CRON_SECRET"
# when this env var exists on the project.
# Generate one with: openssl rand -base64 32
# Leave blank in local dev to allow unauthenticated curl testing.
CRON_SECRET=""
