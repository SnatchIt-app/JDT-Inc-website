# -------------------------------------------------------------
# JDT Inc. — Environment variables
# Copy this file to `.env` for local dev (and add the same vars
# to Vercel → Project Settings → Environment Variables).
# -------------------------------------------------------------

# Postgres connection string (Neon recommended).
# Neon provides a pooled URL — use that here for serverless runtimes.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Secret used to sign admin session JWTs.
# Generate one with: openssl rand -base64 48
AUTH_SECRET="replace-me-with-a-long-random-string"

# Initial admin account (used by `npm run db:seed`).
# Change the password after first login.
# ADMIN_EMAIL is also the recipient of new-lead email notifications.
ADMIN_EMAIL="admin@jdt-inc.com"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_NAME="JDT Admin"

# -------------------------------------------------------------
# Lead email notifications (Resend)
# -------------------------------------------------------------
# Get a key at https://resend.com/api-keys
# Leave RESEND_API_KEY blank locally to disable notifications (the
# app still works; it just skips sending emails).
RESEND_API_KEY="re_D5mp6ZzF_Dvd2CTwvgrr9HF33VLqaLFZm"

# Verified sender — must be on a domain you've verified in Resend.
# Format: "JDT Inc <leads@notifications.jdt-inc.com>"
# For quick local testing, "onboarding@resend.dev" is allowed by Resend
# and will deliver only to the account's own email.
RESEND_FROM="JDT Inc <gnvprod@gmail.com>"

# Base URL used to build links inside the email (e.g. to the lead page).
# Optional locally — defaults to the site URL from `lib/site.ts`.
# Set to "http://localhost:3000" while testing emails from dev.
APP_URL="https://www.jdt-inc.com"

# -------------------------------------------------------------
# Follow-up automation (Vercel Cron)
# -------------------------------------------------------------
# Shared secret required to trigger the cron endpoints:
#   GET /api/cron/follow-ups
#   GET /api/cron/daily-digest
# Vercel Cron automatically sends "Authorization: Bearer $CRON_SECRET"
# when this env var exists on the project.
# Generate one with: openssl rand -base64 32
# Leave blank in local dev to allow unauthenticated curl testing.
CRON_SECRET="eGKMylsrbKsR9YeXEGNyuwCPR60jSfmUtijQrxXiwwA="

# -------------------------------------------------------------
# MCP server (Cowork / Claude integration)
# -------------------------------------------------------------
# Static bearer token required by /api/mcp. Anything calling the MCP
# server must send "Authorization: Bearer $MCP_SECRET".
# Generate one with: openssl rand -base64 32
# Leave blank to disable the endpoint (it will return 401 for everything).
MCP_SECRET=""

# Email of the admin row used to attribute writes coming through the MCP
# server (note creation, status changes, etc.). Auto-created on first call
# if it doesn't exist. If unset, falls back to the first admin in the table.
MCP_ADMIN_EMAIL="mcp-agent@jdt-inc.com"

# -------------------------------------------------------------
# Analytics (Sprint 1 — technical SEO foundation)
# -------------------------------------------------------------
# Set ONE of these. If both are present, GTM takes precedence and GA4
# should be configured as a tag inside the GTM container.
# Leave both empty in development to skip loading any analytics scripts.
#
# Google Tag Manager container ID (e.g. GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=""
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=""

# -------------------------------------------------------------
# Autonomous editorial pipeline
# -------------------------------------------------------------
# Required by scripts/generate-brief.ts and scripts/generate-draft.ts
# (and the .github/workflows/autonomous-draft.yml weekly cron). Set as
# a GitHub Actions secret named ANTHROPIC_API_KEY for the cron to run.
ANTHROPIC_API_KEY=""
